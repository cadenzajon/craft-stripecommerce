{
    "name": "cadenzajon/craft-stripecommerce",
    "description": "Session cart and Stripe Checkout for Craft CMS, with configurable pricing tiers",
    "type": "craft-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.6",
        "craftcms/stripe": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "cadenzajon\\stripecommerce\\": "src/"
        }
    },
    "extra": {
        "handle": "stripe-commerce",
        "name": "Stripe Commerce",
        "developer": "cadenzajon",
        "class": "cadenzajon\\stripecommerce\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
